---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import FaqSection from "../../components/FaqSection.astro";
import { subscriptions, type SubscriptionEntry } from "../../data/subscriptions";

const site = "https://www.renewtracker.net";
const year = new Date().getFullYear();

export function getStaticPaths() {
  return subscriptions.map((s) => ({ params: { slug: s.slug } }));
}

const { slug } = Astro.params;
const entry = subscriptions.find((s) => s.slug === slug);
if (!entry) return Astro.redirect("/404");

const related = subscriptions
  .filter((s) => s.category === entry.category && s.slug !== slug)
  .slice(0, 4);

function renderList(items: string[], numbered: boolean = false) {
  if (numbered) {
    return `<ol class="space-y-3 mb-6">${items.map((item, i) =>
      `<li class="flex items-start gap-3 text-gray-600"><span class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-600 text-white text-xs font-bold flex items-center justify-center mt-0.5">${i + 1}</span><span>${item}</span></li>`
    ).join("")}</ol>`;
  }
  return `<ul class="space-y-2 mb-6">${items.map((item) =>
    `<li class="flex items-start gap-3 text-gray-600"><span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-blue-500 flex-shrink-0"></span><span>${item}</span></li>`
  ).join("")}</ul>`;
}

---

<BaseLayout
  title={`${entry.name} Subscription ${year}: Cost, Renewal Tips & How to Cancel`}
  description={entry.description}
  canonical={`${site}/track/${entry.slug}`}
  breadcrumbs={[{ label: "Track", href: "/track" }, { label: entry.name }]}
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Product",
    name: entry.name + " Subscription",
    description: entry.description,
    category: entry.category,
    offers: {
      "@type": "AggregateOffer",
      priceCurrency: "USD",
      lowPrice: (entry.pricing.match(/\$[\d.]+/)?.[0]?.replace("$", "")) || "0",
      highPrice: (entry.pricing.match(/\$[\d.]+/g)?.pop()?.replace("$", "")) || "0",
      offerCount: "1",
      availability: "https://schema.org/OnlineOnly",
    },
    url: site + "/track/" + entry.slug,
    ...(entry.url ? { sameAs: entry.url } : {}),
  })} />
  <div class="min-h-screen bg-white">
    <Navbar currentPath={Astro.url.pathname} />

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-16">
      <div class="mb-6">
        <Breadcrumbs items={[{ label: "Track", href: "/track" }, { label: entry.name }]} />
      </div>

      <header class="mb-10">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs font-semibold px-3 py-1 bg-blue-100 text-blue-700 rounded-full capitalize">{entry.category}</span>
        </div>

        <h1 class="text-2xl sm:text-4xl font-bold text-gray-900 leading-tight mb-4">{entry.name}</h1>

        <div class="flex flex-wrap gap-4 mb-5">
          <div class="flex items-center gap-2 text-sm text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-500"><circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/></svg>
            <span class="font-semibold text-gray-900">{entry.billingCycle}</span>
          </div>
          <div class="flex items-center gap-2 text-sm text-gray-600">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><line x1="12" x2="12" y1="1" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            <span class="font-semibold text-gray-900">{entry.pricing}</span>
          </div>
        </div>

        <p class="text-base sm:text-lg text-gray-500 leading-relaxed border-l-4 border-blue-400 pl-5 py-1">{entry.description}</p>
      </header>

      <hr class="border-gray-100 mb-8" />

      <div class="prose-sm max-w-none">
        <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mt-10 mb-4">Renewal Tips for {entry.name}</h2>
        <div set:html={renderList(entry.renewalTips, true)} />

        <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mt-10 mb-4">How to Cancel {entry.name}</h2>
        <div set:html={renderList(entry.cancellationTips, true)} />

        <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mt-10 mb-4">Frequently Asked Questions</h2>
        <FaqSection items={entry.faq || []} />
      </div>

      <div class="mt-14 bg-gray-50 border border-gray-200 rounded-2xl p-6 sm:p-7">
        <h3 class="text-base font-bold text-gray-900 mb-3">Free tools for tracking {entry.name}</h3>
        <div class="flex flex-wrap gap-2">
          <a href="/tools/subscription-calculator" class="text-xs font-medium bg-white border border-gray-200 text-gray-700 px-3 py-1.5 rounded-lg hover:border-blue-300 hover:text-blue-600 transition-colors">Subscription Cost Calculator</a>
          <a href="/tools/renewal-reminder-tool" class="text-xs font-medium bg-white border border-gray-200 text-gray-700 px-3 py-1.5 rounded-lg hover:border-blue-300 hover:text-blue-600 transition-colors">Renewal Reminder Planner</a>
          <a href="/blog/stop-paying-for-subscriptions-you-forgot" class="text-xs font-medium bg-white border border-gray-200 text-gray-700 px-3 py-1.5 rounded-lg hover:border-blue-300 hover:text-blue-600 transition-colors">Find Forgotten Subscriptions</a>
          <a href="/blog/subscription-audit-save-money" class="text-xs font-medium bg-white border border-gray-200 text-gray-700 px-3 py-1.5 rounded-lg hover:border-blue-300 hover:text-blue-600 transition-colors">Subscription Audit Guide</a>
          <a href="/blog/annual-vs-monthly-billing" class="text-xs font-medium bg-white border border-gray-200 text-gray-700 px-3 py-1.5 rounded-lg hover:border-blue-300 hover:text-blue-600 transition-colors">Annual vs Monthly Billing</a>
        </div>
      </div>

      <div class="mt-14 bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl p-6 sm:p-8 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-200 mx-auto mb-3"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>
        <h3 class="text-xl font-bold text-white mb-2">Track {entry.name} and all your subscriptions free with RenewTracker</h3>
        <p class="text-blue-200 text-sm mb-5">Add {entry.name} and every other subscription, bill, and renewal to your personal dashboard. Get email reminders before every due date — never miss a payment.</p>
        <a href="/register" class="inline-flex items-center gap-2 bg-white text-blue-700 font-semibold text-sm px-5 py-2.5 rounded-xl hover:bg-blue-50 transition-colors">
          Get started free <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>

      {related.length > 0 && (
        <div class="mt-14 bg-gray-50 rounded-2xl p-6 sm:p-8">
          <h3 class="text-lg font-bold text-gray-900 mb-5">More {entry.category} subscriptions</h3>
          <div class="grid sm:grid-cols-2 gap-4">
            {related.map((r) => (
              <a key={r.slug} href={`/track/${r.slug}`} class="group bg-white border border-gray-100 rounded-xl p-4 hover:border-blue-200 hover:shadow-sm transition-all">
                <p class="text-xs font-semibold text-blue-600 mb-1 capitalize">{r.category}</p>
                <h4 class="font-semibold text-gray-900 text-sm group-hover:text-blue-700 transition-colors">{r.name}</h4>
                <p class="text-xs text-gray-500 mt-1 line-clamp-2">{r.description}</p>
              </a>
            ))}
          </div>
        </div>
      )}
    </div>

    <Footer />
  </div>
</BaseLayout>
