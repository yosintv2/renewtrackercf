---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import HomeContent from "../components/HomeContent";
---

<BaseLayout
  title="RenewTracker — Never Miss a Payment"
  description="Track every subscription, bill, rent, loan, and recurring payment in one place. Get free reminders before every due date. Netflix, Spotify, rent, credit cards, BNPL — all in one dashboard. Forever free."
>
  <div class="min-h-screen bg-white overflow-x-hidden">
    <Navbar currentPath={Astro.url.pathname} />
    <HomeContent client:load />
    <Footer />
  </div>
</BaseLayout>
