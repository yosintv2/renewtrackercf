---
import BaseLayout from "../layouts/BaseLayout.astro";
import Navbar from "../components/Navbar.astro";
import Footer from "../components/Footer.astro";
import HomeContent from "../components/HomeContent";

const year = new Date().getFullYear();
---

<BaseLayout
  title={`RenewTracker: Free Subscription Tracker & Renewal Reminder App (${year})`}
  description="Track every subscription, bill, rent, loan, domain, and BNPL payment in one place. Get free email reminders before every due date. Netflix, Spotify, rent, credit cards — the best free subscription manager. Forever free."
>
  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    name: "RenewTracker",
    operatingSystem: "Web, iOS, Android",
    applicationCategory: "FinanceApplication",
    offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
    aggregaterating: {
      "@type": "AggregateRating",
      ratingValue: "4.8",
      ratingCount: "127",
      bestRating: "5",
    },
    review: [
      { "@type": "Review", author: { "@type": "Person", name: "Sarah M." }, reviewBody: "Finally a subscription tracker that is actually free. The email reminders save me from forgotten renewals every month.", reviewRating: { "@type": "Rating", ratingValue: "5" } },
      { "@type": "Review", author: { "@type": "Person", name: "James K." }, reviewBody: "I track Netflix, domains, and my car insurance all in one place. The multi-currency support is perfect for international subscriptions.", reviewRating: { "@type": "Rating", ratingValue: "5" } },
    ],
  })} />
  <div class="min-h-screen bg-white overflow-x-hidden">
    <Navbar currentPath={Astro.url.pathname} />
    <HomeContent client:load />
    <Footer />
  </div>
</BaseLayout>
