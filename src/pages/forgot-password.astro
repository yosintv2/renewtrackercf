---
import BaseLayout from "../layouts/BaseLayout.astro";
import ForgotPasswordForm from "../components/ForgotPasswordForm";
---

<BaseLayout title="Forgot password — RenewTracker">
  <div class="min-h-screen bg-gray-50 flex flex-col lg:flex-row">
    <div class="hidden lg:flex lg:w-1/2 bg-gradient-to-br from-blue-600 to-indigo-700 flex-col justify-between p-8 relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;"></div>
      <a href="/" class="relative inline-flex items-center gap-2.5 font-bold text-lg text-white">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="none" class="w-8 h-8">
          <rect width="32" height="32" rx="8" fill="rgba(255,255,255,0.2)"/>
          <path d="M16 5.5L25 8.5V16C25 22 21 26 16 27.5C11 26 7 22 7 16V8.5L16 5.5Z" fill="white"/>
        </svg>
        RenewTracker
      </a>
      <div class="relative">
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3 leading-tight">Forgot your password?</h2>
        <p class="text-blue-200 text-sm sm:text-base mb-5 max-w-sm">No worries. Enter your email and we&apos;ll send you a reset link.</p>
      </div>
      <p class="relative text-blue-300 text-xs">Free for everyone, forever.</p>
    </div>

    <div class="flex-1 flex flex-col items-center justify-center px-4 py-4 lg:overflow-y-auto">
      <div class="w-full max-w-md">
        <div class="text-center mb-4 lg:hidden">
          <a href="/" class="inline-flex items-center gap-2.5 font-bold text-lg mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="none" class="w-8 h-8">
              <rect width="32" height="32" rx="8" fill="#2563EB"/>
              <path d="M16 5.5L25 8.5V16C25 22 21 26 16 27.5C11 26 7 22 7 16V8.5L16 5.5Z" fill="white"/>
            </svg>
            <span class="text-gray-900">Renew<span class="text-blue-600">Tracker</span></span>
          </a>
        </div>

        <h1 class="text-xl sm:text-2xl font-bold text-gray-900 mb-1 lg:text-center">Reset your password</h1>
        <p class="text-gray-500 text-sm mb-5 lg:text-center">We&apos;ll send a reset link to your email.</p>

        <ForgotPasswordForm client:load />

        <p class="text-center text-sm text-gray-500 mt-4">
          <a href="/login" class="inline-flex items-center gap-1.5 text-blue-600 font-medium hover:text-blue-700">
            <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m12 19-7-7 7-7"/><path d="M19 12H5"/></svg>
            Back to sign in
          </a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
