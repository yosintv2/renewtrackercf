---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import FaqSection from "../../components/FaqSection.astro";
import { domains, type DomainEntry } from "../../data/domains";

const site = "https://www.renewtracker.net";
const year = new Date().getFullYear();

export function getStaticPaths() {
  return domains.map((d) => ({ params: { slug: d.slug } }));
}

const { slug } = Astro.params;
const entry = domains.find((d) => d.slug === slug);
if (!entry) return Astro.redirect("/404");

function renderList(items: string[], numbered: boolean = false) {
  if (numbered) {
    return `<ol class="space-y-3 mb-6">${items.map((item, i) =>
      `<li class="flex items-start gap-3 text-gray-600"><span class="flex-shrink-0 w-6 h-6 rounded-full bg-blue-600 text-white text-xs font-bold flex items-center justify-center mt-0.5">${i + 1}</span><span>${item}</span></li>`
    ).join("")}</ol>`;
  }
  return `<ul class="space-y-2 mb-6">${items.map((item) =>
    `<li class="flex items-start gap-3 text-gray-600"><span class="mt-1.5 w-1.5 h-1.5 rounded-full bg-blue-500 flex-shrink-0"></span><span>${item}</span></li>`
  ).join("")}</ul>`;
}

---

<BaseLayout
  title={entry.name.match(/domain|expir|renewal|ssl|certificate|registrar|cost|checker|check/i) ? (entry.name.includes(year.toString()) ? entry.name : `${entry.name} (${year})`) : `${entry.name} Domain Renewal (${year})`}
  description={entry.description}
  canonical={`${site}/domains/${entry.slug}`}
  breadcrumbs={[{ label: "Domains", href: "/domains" }, { label: entry.name }]}
>
  <div class="min-h-screen bg-white">
    <Navbar currentPath={Astro.url.pathname} />

    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-16">
      <div class="mb-6">
        <Breadcrumbs items={[{ label: "Domain Renewals", href: "/domains" }, { label: entry.name }]} />
      </div>

      <header class="mb-10">
        <h1 class="text-2xl sm:text-4xl font-bold text-gray-900 leading-tight mb-4">{entry.name}</h1>
        {entry.pricing && (
          <div class="flex items-center gap-2 text-sm text-gray-600 mb-4">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500"><line x1="12" x2="12" y1="1" y2="23"/><path d="M17 5H9.5a3.5 3.5 0 0 0 0 7h5a3.5 3.5 0 0 1 0 7H6"/></svg>
            <span class="font-semibold text-gray-900">{entry.pricing}</span>
          </div>
        )}
        <p class="text-base sm:text-lg text-gray-500 leading-relaxed border-l-4 border-blue-400 pl-5 py-1">{entry.description}</p>
      </header>

      <hr class="border-gray-100 mb-8" />

      <div class="prose-sm max-w-none">
        <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mt-10 mb-4">Services Offered</h2>
        <div set:html={renderList(entry.services)} />

        <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mt-10 mb-4">Renewal Tips for {entry.name}</h2>
        <div set:html={renderList(entry.renewalTips, true)} />

        <h2 class="text-xl sm:text-2xl font-bold text-gray-900 mt-10 mb-4">Frequently Asked Questions</h2>
        <FaqSection items={entry.faq || []} />
      </div>

      <div class="mt-12 bg-gray-50 border border-gray-200 rounded-2xl p-6 sm:p-7">
        <h3 class="text-base font-bold text-gray-900 mb-3">Related domain tools</h3>
        <div class="flex flex-wrap gap-2">
          <a href="/tools/domain-expiry-calculator" class="text-xs font-medium bg-white border border-gray-200 text-gray-700 px-3 py-1.5 rounded-lg hover:border-blue-300 hover:text-blue-600 transition-colors">Domain Expiry Calculator</a>
          <a href="/tools/hosting-renewal-calculator" class="text-xs font-medium bg-white border border-gray-200 text-gray-700 px-3 py-1.5 rounded-lg hover:border-blue-300 hover:text-blue-600 transition-colors">Hosting Renewal Calculator</a>
          <a href="/tools/renewal-reminder-tool" class="text-xs font-medium bg-white border border-gray-200 text-gray-700 px-3 py-1.5 rounded-lg hover:border-blue-300 hover:text-blue-600 transition-colors">Renewal Reminder Planner</a>
          <a href="/blog/domain-subscription-tracker-combined" class="text-xs font-medium bg-white border border-gray-200 text-gray-700 px-3 py-1.5 rounded-lg hover:border-blue-300 hover:text-blue-600 transition-colors">Domain & Subscription Tracker Guide</a>
          <a href="/domains/domain-renewal-price-comparison" class="text-xs font-medium bg-white border border-gray-200 text-gray-700 px-3 py-1.5 rounded-lg hover:border-blue-300 hover:text-blue-600 transition-colors">Compare Domain Renewal Prices</a>
        </div>
      </div>

      <div class="mt-14 bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl p-6 sm:p-8 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-200 mx-auto mb-3"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>
        <h3 class="text-xl font-bold text-white mb-2">Track domain renewals free with RenewTracker</h3>
        <p class="text-blue-200 text-sm mb-5">Never let a domain expire again. Add all your domains, hosting, and SSL certificates to RenewTracker and get email reminders before every renewal.</p>
        <a href="/register" class="inline-flex items-center gap-2 bg-white text-blue-700 font-semibold text-sm px-5 py-2.5 rounded-xl hover:bg-blue-50 transition-colors">
          Get started free <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <Footer />
  </div>
</BaseLayout>
