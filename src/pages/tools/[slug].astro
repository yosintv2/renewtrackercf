---
import BaseLayout from "../../layouts/BaseLayout.astro";
import Navbar from "../../components/Navbar.astro";
import Footer from "../../components/Footer.astro";
import Breadcrumbs from "../../components/Breadcrumbs.astro";
import FaqSection from "../../components/FaqSection.astro";
import SubscriptionCalculator from "../../components/tools/SubscriptionCalculator";
import MonthlySubscriptionCalculator from "../../components/tools/MonthlySubscriptionCalculator";
import YearlySubscriptionCalculator from "../../components/tools/YearlySubscriptionCalculator";
import DomainExpiryCalculator from "../../components/tools/DomainExpiryCalculator";
import HostingRenewalCalculator from "../../components/tools/HostingRenewalCalculator";
import RenewalReminderTool from "../../components/tools/RenewalReminderTool";
import { tools } from "../../data/tools";

const site = "https://www.renewtracker.net";
const year = new Date().getFullYear();

export async function getStaticPaths() {
  return tools.map((tool) => ({
    params: { slug: tool.slug },
  }));
}

const { slug } = Astro.params;
const tool = tools.find((t) => t.slug === slug);

if (!tool) {
  return Astro.redirect("/404");
}

---

<BaseLayout title={tool.title + " (" + year + ") — Free Online Tool"} description={tool.metaDescription} canonical={site + "/tools/" + tool.slug} breadcrumbs={[{ label: "Tools", href: "/tools" }, { label: tool.title }]}>
  <div class="min-h-screen bg-white">
    <Navbar currentPath={Astro.url.pathname} />

    <div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 pt-28 pb-16">
      <div class="mb-6">
        <Breadcrumbs items={[{ label: "Tools", href: "/tools" }, { label: tool.title }]} />
      </div>

      <header class="mb-10">
        <h1 class="text-3xl sm:text-4xl font-bold text-gray-900 leading-tight mb-3">{tool.title}</h1>
        <p class="text-lg text-gray-500 leading-relaxed">{tool.description}</p>
      </header>

      <div class="bg-gray-50 border border-gray-200 rounded-2xl p-6 sm:p-8 mb-14">
        {tool.component === "SubscriptionCalculator" && <SubscriptionCalculator client:load />}
        {tool.component === "MonthlySubscriptionCalculator" && <MonthlySubscriptionCalculator client:load />}
        {tool.component === "YearlySubscriptionCalculator" && <YearlySubscriptionCalculator client:load />}
        {tool.component === "DomainExpiryCalculator" && <DomainExpiryCalculator client:load />}
        {tool.component === "HostingRenewalCalculator" && <HostingRenewalCalculator client:load />}
        {tool.component === "RenewalReminderTool" && <RenewalReminderTool client:load />}
      </div>

      <section class="mb-14">
        <h2 class="text-xl font-bold text-gray-900 mb-6">Frequently Asked Questions</h2>
        <FaqSection items={tool.faq} />
      </section>

      <div class="bg-gradient-to-br from-blue-600 to-indigo-700 rounded-2xl p-6 sm:p-8 text-center">
        <svg xmlns="http://www.w3.org/2000/svg" width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-200 mx-auto mb-3"><path d="M4 19.5v-15A2.5 2.5 0 0 1 6.5 2H19a1 1 0 0 1 1 1v18a1 1 0 0 1-1 1H6.5a1 1 0 0 1 0-5H20"/></svg>
        <h3 class="text-xl font-bold text-white mb-2">Start tracking your renewals today</h3>
        <p class="text-blue-200 text-sm mb-5">Create a free account to save your calculations and get reminders before every due date.</p>
        <a href="/register" class="inline-flex items-center gap-2 bg-white text-blue-700 font-semibold text-sm px-5 py-2.5 rounded-xl hover:bg-blue-50 transition-colors">
          Get started free <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
        </a>
      </div>
    </div>

    <Footer />
  </div>
</BaseLayout>
