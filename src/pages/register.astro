---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegisterForm from "../components/RegisterForm";
---

<BaseLayout title="Create Free Account — Start Tracking Subscriptions & Renewals | RenewTracker" description="Create your free RenewTracker account. No credit card required. Track unlimited subscriptions, bills, domains, and recurring payments. Get free email reminders before every due date.">
  <div class="min-h-screen bg-gray-50 flex flex-col lg:flex-row">
    <div class="hidden lg:flex lg:w-1/2 bg-gradient-to-br from-blue-600 to-indigo-700 flex-col justify-between p-8 relative overflow-hidden">
      <div class="absolute inset-0 opacity-[0.03]" style="background-image: radial-gradient(circle at 1px 1px, white 1px, transparent 0); background-size: 24px 24px;"></div>
      <a href="/" class="relative inline-flex items-center gap-2.5 font-bold text-lg text-white">
        <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="none" class="w-8 h-8">
          <rect width="32" height="32" rx="8" fill="rgba(255,255,255,0.2)"/>
          <path d="M16 5.5L25 8.5V16C25 22 21 26 16 27.5C11 26 7 22 7 16V8.5L16 5.5Z" fill="white"/>
        </svg>
        RenewTracker
      </a>
      <div class="relative">
        <h2 class="text-2xl sm:text-3xl font-bold text-white mb-3 leading-tight">Never miss a subscription payment again.</h2>
        <p class="text-blue-200 text-sm sm:text-base mb-5 max-w-sm">Join thousands who use RenewTracker to stay on top of every recurring payment and bill.</p>
        <ul class="space-y-2.5">
          {["Track subscriptions, bills, rent, and financial liabilities","Get reminders 30, 15, 7, 3, and 1 day before every payment","See your monthly and yearly spend breakdown by category","100% free — no limits, no credit card required"].map((b) => (
            <li class="flex items-start gap-2.5 text-white text-sm">
              <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-300 flex-shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="text-blue-100">{b}</span>
            </li>
          ))}
        </ul>
      </div>
      <p class="relative text-blue-300 text-xs">Free for everyone, forever.</p>
    </div>

    <div class="flex-1 flex flex-col items-center justify-center px-4 py-4 lg:overflow-y-auto">
      <div class="w-full max-w-md">
        <div class="text-center mb-4 lg:hidden">
          <a href="/" class="inline-flex items-center gap-2.5 font-bold text-lg mb-3">
            <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 32 32" fill="none" class="w-8 h-8">
              <rect width="32" height="32" rx="8" fill="#2563EB"/>
              <path d="M16 5.5L25 8.5V16C25 22 21 26 16 27.5C11 26 7 22 7 16V8.5L16 5.5Z" fill="white"/>
            </svg>
            <span class="text-gray-900">Renew<span class="text-blue-600">Tracker</span></span>
          </a>
        </div>

        <h1 class="text-xl sm:text-2xl font-bold text-gray-900 mb-1 lg:text-center">Create your free account</h1>
        <p class="text-gray-500 text-sm mb-5 lg:text-center">No credit card required. Free forever, no limits.</p>

        <RegisterForm client:load />

        <p class="text-center text-sm text-gray-500 mt-4">
          Already have an account?{" "}
          <a href="/login" class="text-blue-600 font-medium hover:text-blue-700">Sign in</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
