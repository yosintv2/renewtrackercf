---
import BaseLayout from "../layouts/BaseLayout.astro";
import RegisterForm from "../components/RegisterForm";
---

<BaseLayout title="Create a free account — RenewTracker" description="Create your free RenewTracker account. No credit card required. Track every subscription, bill, and recurring payment.">
  <div class="min-h-screen bg-gray-50 flex flex-col lg:flex-row">
    <div class="hidden lg:flex lg:w-1/2 bg-blue-600 flex-col justify-between p-12">
      <a href="/" class="inline-flex items-center gap-2 font-bold text-xl text-white">
        <div class="w-9 h-9 rounded-xl bg-white/20 flex items-center justify-center">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/></svg>
        </div>
        RenewTracker
      </a>
      <div>
        <h2 class="text-4xl font-bold text-white mb-4 leading-tight">Never miss a subscription payment again.</h2>
        <p class="text-blue-200 text-lg mb-8">Join thousands who use RenewTracker to stay on top of every recurring payment and bill.</p>
        <ul class="space-y-4">
          {["Track subscriptions, bills, rent, and financial liabilities","Get reminders 30, 15, 7, 3, and 1 day before every payment","See your monthly and yearly spend breakdown by category","100% free — no limits, no credit card required"].map((b) => (
            <li class="flex items-start gap-3 text-white">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-blue-300 flex-shrink-0 mt-0.5"><path d="M20 6 9 17l-5-5"/></svg>
              <span class="text-blue-100">{b}</span>
            </li>
          ))}
        </ul>
      </div>
      <p class="text-blue-300 text-sm">Free for everyone, forever.</p>
    </div>

    <div class="flex-1 flex flex-col items-center justify-center px-4 py-16">
      <div class="w-full max-w-md">
        <div class="text-center mb-8 lg:hidden">
          <a href="/" class="inline-flex items-center gap-2 font-bold text-xl mb-4">
            <div class="w-9 h-9 rounded-xl bg-blue-600 flex items-center justify-center">
              <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s-8-4.5-8-11.8A8 8 0 0 1 12 2a8 8 0 0 1 8 8.2c0 7.3-8 11.8-8 11.8z"/></svg>
            </div>
            <span class="text-gray-900">Renew<span class="text-blue-600">Tracker</span></span>
          </a>
        </div>

        <h1 class="text-2xl font-bold text-gray-900 mb-1">Create your free account</h1>
        <p class="text-gray-500 text-sm mb-8">No credit card required. Free forever, no limits.</p>

        <RegisterForm client:load />

        <p class="text-center text-sm text-gray-500 mt-6">
          Already have an account?{" "}
          <a href="/login" class="text-blue-600 font-medium hover:text-blue-700">Sign in</a>
        </p>
      </div>
    </div>
  </div>
</BaseLayout>
