---
import "../styles/globals.css";

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  breadcrumbs?: { label: string; href?: string }[];
}

const site = "https://www.renewtracker.net";
const defaultTitle = "RenewTracker — Never Miss a Subscription Payment";
const defaultDesc = "Track every subscription, bill, rent, loan, and recurring payment in one place. Free email reminders before every due date — Netflix, Spotify, rent, domains, BNPL, and more. Forever free.";
const { title = defaultTitle, description = defaultDesc, canonical, ogImage = "/apple-icon.png", breadcrumbs } = Astro.props;

const pageTitle = title.includes("RenewTracker") ? title : `${title} — RenewTracker`;

const path = Astro.url.pathname.endsWith("/") ? Astro.url.pathname : Astro.url.pathname + "/";

const author = "RenewTracker Team";
const publisher = "RenewTracker";

const jsonLd = [];

jsonLd.push({
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "RenewTracker",
  url: site,
  description: defaultDesc,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  author: { "@type": "Organization", name: "RenewTracker" },
  publisher: { "@type": "Organization", name: "RenewTracker" },
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
});

if (breadcrumbs && breadcrumbs.length > 0) {
  jsonLd.push({
    "@context": "https://schema.org",
    "@type": "BreadcrumbList",
    itemListElement: [
      { "@type": "ListItem", position: 1, name: "Home", item: site + "/" },
      ...breadcrumbs.map((b, i) => ({
        "@type": "ListItem",
        position: i + 2,
        name: b.label,
        ...(b.href ? { item: site + b.href } : {}),
      })),
    ],
  });
}
---

<!doctype html>
<html lang="en" class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="subscription tracker, subscription manager, renewal reminder, free subscription tracker, domain renewal tracker, bill reminder, recurring payment tracker, BNPL tracker" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#2563eb" />
    <link rel="canonical" href={canonical || site + Astro.url.pathname} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-icon.png" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical || site + Astro.url.pathname} />
    <meta property="og:image" content={site + ogImage} />
    <meta property="og:site_name" content="RenewTracker" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={site + ogImage} />

    {jsonLd.length === 1 ? (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd[0])} />
    ) : (
      jsonLd.map((ld) => <script type="application/ld+json" set:html={JSON.stringify(ld)} />)
    )}

    <script async src="https://www.googletagmanager.com/gtag/js?id=G-GVZZSHSQM0"></script>
    <script>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-GVZZSHSQM0');
    </script>

    <link rel="preconnect" href="https://api.fontshare.com" />
    <style>
      @font-face {
        font-family: 'Geist';
        src: url('https://api.fontshare.com/v2/css?f[]=geist@400,500,600,700&display=swap') format('woff2');
        font-display: swap;
      }
      @font-face {
        font-family: 'Geist Mono';
        src: url('https://api.fontshare.com/v2/css?f[]=geist-mono@400,500,700&display=swap') format('woff2');
        font-display: swap;
      }
    </style>
  </head>
  <body class="min-h-full flex flex-col">
    <slot />
  </body>
</html>
