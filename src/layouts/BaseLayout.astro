---
import "../styles/globals.css";

export interface Props {
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
}

const site = "https://www.renewtracker.net";
const defaultTitle = "RenewTracker — Never Miss a Payment";
const defaultDesc = "Track every subscription, bill, rent, loan, and recurring payment in one place. Free reminders before every due date — Netflix, rent, credit cards, BNPL, and more.";
const { title = defaultTitle, description = defaultDesc, canonical, ogImage = "/apple-icon.png" } = Astro.props;

const pageTitle = title.includes("RenewTracker") ? title : `${title} — RenewTracker`;
const jsonLd = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: "RenewTracker",
  url: site,
  description: defaultDesc,
  applicationCategory: "FinanceApplication",
  operatingSystem: "Web",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
};
---

<!doctype html>
<html lang="en" class="h-full antialiased">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, maximum-scale=5" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <meta name="keywords" content="subscription tracker,bill reminder,recurring payment tracker,subscription management,monthly bill organizer,BNPL tracker,rent reminder,credit card payment reminder,free subscription manager,renewtracker" />
    <meta name="robots" content="index, follow" />
    <meta name="theme-color" content="#2563eb" />
    <link rel="canonical" href={canonical || site + Astro.url.pathname} />

    <link rel="icon" type="image/x-icon" href="/favicon.ico" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-icon.png" />

    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonical || site + Astro.url.pathname} />
    <meta property="og:image" content={site + ogImage} />
    <meta property="og:site_name" content="RenewTracker" />
    <meta property="og:locale" content="en_US" />

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={site + ogImage} />

    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />

    <link rel="preconnect" href="https://api.fontshare.com" />
    <style>
      @font-face {
        font-family: 'Geist';
        src: url('https://api.fontshare.com/v2/css?f[]=geist@400,500,600,700&display=swap') format('woff2');
        font-display: swap;
      }
      @font-face {
        font-family: 'Geist Mono';
        src: url('https://api.fontshare.com/v2/css?f[]=geist-mono@400,500,700&display=swap') format('woff2');
        font-display: swap;
      }
    </style>
  </head>
  <body class="min-h-full flex flex-col">
    <slot />
  </body>
</html>
